---
import Layout from "@layouts/Layout.astro";
import About from "@components/sections/About.astro";
import Education from "@/components/sections/Education.astro";
import Experience from "@/components/sections/Experience.astro";
import Hero from "@/components/sections/Hero.astro";
import Projects from "@/components/sections/Projects.astro";
import Publications from "@/components/sections/Publications.astro";
import Skills from "@/components/sections/Skills.astro";
import KeyboardManager from "@/components/KeyboardManager.astro";
import { data, type Locale } from "@lib/cv";

const locales: Locale[] = ["en", "es"];
---

<Layout title="Francisco Olmedo — CV">
	<main
		class="mx-auto my-6 max-w-3xl rounded-xl bg-white px-8 py-10 pb-16 text-gray-800 shadow-sm ring-1 ring-gray-200 print:my-0 print:rounded-none print:shadow-none print:ring-0"
	>
		{
			locales.map((lng) => (
				<div data-lang-wrap={lng}>
					<Hero data={data[lng]} lang={lng} />
					<About data={data[lng]} lang={lng} />
					<Experience data={data[lng]} lang={lng} />
					<Projects data={data[lng]} lang={lng} />
					<Publications data={data[lng]} lang={lng} />
					<Education data={data[lng]} lang={lng} />
					<Skills data={data[lng]} lang={lng} />
				</div>
			))
		}
	</main>

	<KeyboardManager />
</Layout>
