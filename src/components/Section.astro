---
const { title } = Astro.props;
---

<section class="mb-6">
	{
		title && (
			<h2 class="mb-3 flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-blue-900">
				<span class="inline-block h-[2px] w-6 bg-blue-900" />
				{title}
			</h2>
		)
	}
	<div class="text-[13px] leading-relaxed text-gray-700">
		<slot />
	</div>
</section>
