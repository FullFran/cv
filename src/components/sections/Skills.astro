---
import Section from "../Section.astro";
import SkillsLanguages from "../SkillsLanguages.astro";
import { skills, languages } from "@cv";

// Transformar skills del JSON al formato que espera SkillsLanguages
const skillGroups = skills.map((group) => ({
  title: group.name,
  skills: group.keywords,
}));

// Transformar languages del JSON
const languageItems = languages.map((lang) => {
  const fluency = lang.fluency ? ` (${lang.fluency})` : "";
  return `${lang.language}${fluency}`;
});

const languagesGroup = {
  title: "Languages",
  skills: languageItems,
};
---

<Section title="Technical Skills">
  <SkillsLanguages groups={skillGroups} />
</Section>

<Section title="Languages">
  <div class="grid grid-cols-2 text-xs text-gray-800">
    {languages.map((lang) => (
      <div>
        <p class="font-semibold">{lang.language}</p>
        <p class="text-gray-600">{lang.fluency}</p>
      </div>
    ))}
  </div>
</Section>
