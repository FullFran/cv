---
import Section from "../Section.astro";
import SkillsLanguages from "../SkillsLanguages.astro";
import type { CVData, Locale } from "@lib/cv";
import { labels } from "@lib/cv";

interface Props {
  data: CVData;
  lang: Locale;
}

const { data, lang } = Astro.props;
const t = labels[lang];

const skillGroups = data.skills.map((group) => ({
  title: group.name,
  skills: group.keywords,
}));
---

<Section title={t.skills}>
  <SkillsLanguages groups={skillGroups} />
</Section>

<Section title={t.languages}>
  <ul class="flex flex-wrap gap-x-6 gap-y-1">
    {
      data.languages.map((lng) => (
        <li class="flex items-baseline gap-2">
          <span class="text-[13px] font-semibold text-gray-900">
            {lng.language}
          </span>
          {lng.fluency && (
            <span class="text-xs text-gray-500">· {lng.fluency}</span>
          )}
        </li>
      ))
    }
  </ul>
</Section>
