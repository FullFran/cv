---
import Section from "@components/Section.astro";
import Timeline from "@components/Timeline.astro";
import type { CVData, Locale } from "@lib/cv";
import { labels } from "@lib/cv";

interface Props {
  data: CVData;
  lang: Locale;
}

const { data, lang } = Astro.props;
const t = labels[lang];

const joiner = lang === "es" ? " en " : " in ";

const eduItems = data.education.map((item) => ({
  title: `${item.studyType}${joiner}${item.area}`,
  subtitle: item.institution,
  startDate: item.startDate,
  endDate: item.endDate,
}));
---

<Section title={t.education}>
  <Timeline items={eduItems} lang={lang} />
</Section>
