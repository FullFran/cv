---
import type { CVData, Locale } from "@lib/cv";
import { labels } from "@lib/cv";

interface Props {
  data: CVData;
  lang: Locale;
}

const { data, lang } = Astro.props;
const t = labels[lang];
const { name, label, email, location, profiles, url } = data.basics;
const { address } = location;

const contactLinks = [
  { label: t.web, href: url, text: new URL(url).hostname },
  { label: t.email, href: `mailto:${email}`, text: email },
  ...profiles.map((p) => ({ label: p.network, href: p.url, text: p.network })),
];
---

<header class="mb-8 border-b border-gray-200 pb-6">
  <h1 class="text-[28px] font-bold leading-tight tracking-tight text-gray-900">
    {name}
  </h1>
  <p class="mt-1 text-sm font-medium text-blue-900">{label}</p>
  <p class="mt-2 text-xs text-gray-500">{address}</p>

  <ul
    class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-gray-600"
  >
    {
      contactLinks.map((link, i) => (
        <li class="flex items-center gap-3">
          {i > 0 && <span class="text-gray-300">·</span>}
          <a
            href={link.href}
            target={link.href.startsWith("mailto") ? "_self" : "_blank"}
            rel="noopener"
            class="text-blue-700 transition-colors hover:text-blue-900 hover:underline"
          >
            <span class="text-gray-500">{link.label}:</span> {link.text}
          </a>
        </li>
      ))
    }
  </ul>
</header>
