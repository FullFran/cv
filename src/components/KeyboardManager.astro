---
/*
  KeyboardManager.astro
  Renders: status bar, help modal, command prompt, search prompt, slides progress bar.
  Owns: keyboard shortcuts, mode switching (cv|tui|slides), language toggle,
        slide navigation, PDF export trigger, TUI command history/completion,
        lightweight section search.
*/
---

<div class="slide-progress" aria-hidden="true">
  <div class="slide-progress-fill" id="slide-progress-fill"></div>
</div>

<footer class="status-bar no-print" id="status-bar" aria-label="CV controls and status">
  <span class="sb-seg">
    <span class="sb-dot" aria-hidden="true"></span>
    <span>mode:</span>
    <span class="sb-mode" id="sb-mode">CV</span>
  </span>
  <span class="sb-seg">
    <span>lang:</span>
    <span class="sb-lang" id="sb-lang">EN</span>
  </span>
  <span class="sb-seg">
    <span>section:</span>
    <span class="sb-current" id="sb-current">Intro</span>
  </span>
  <span id="sb-slide" class="sb-seg" hidden>
    <span id="sb-slide-text">[1/1]</span>
  </span>
  <span class="sb-spacer"></span>
  <span class="sb-seg sb-actions">
    <button type="button" class="sb-button" id="help-open" aria-haspopup="dialog" aria-controls="help-modal">
      <kbd>?</kbd><span>help</span>
    </button>
    <button type="button" class="sb-button" id="search-open">
      <kbd>/</kbd><span>search</span>
    </button>
    <button type="button" class="sb-button" id="command-open">
      <kbd>:</kbd><span>cmd</span>
    </button>
    <span>·</span>
    <kbd>1</kbd><kbd>2</kbd><kbd>3</kbd><span>modes</span>
    <span>·</span>
    <kbd>[</kbd><kbd>]</kbd><span>sections</span>
    <span>·</span>
    <kbd>H</kbd><kbd>M</kbd><kbd>L</kbd>
  </span>
</footer>

<div class="cmd-prompt" id="cmd-prompt" hidden>
  <span class="cmd-prefix" aria-hidden="true">:</span>
  <input
    id="cmd-input"
    type="text"
    autocomplete="off"
    spellcheck="false"
    aria-label="Command prompt"
    placeholder="Type a command, then press Enter"
  />
</div>

<div class="search-prompt" id="search-prompt" hidden>
  <span class="cmd-prefix" aria-hidden="true">/</span>
  <input
    id="search-input"
    type="text"
    autocomplete="off"
    spellcheck="false"
    aria-label="Search sections"
    placeholder="Search sections or content"
  />
  <span class="search-meta" id="search-meta">0 matches</span>
</div>

<div class="cmd-echo" id="cmd-echo" data-visible="false" role="status" aria-live="polite"></div>
<div class="sr-only" id="sr-updates" aria-live="polite"></div>

<div class="cv-overlay" id="help-modal" role="dialog" aria-modal="true" aria-labelledby="help-title" hidden>
  <div class="cv-overlay-card" role="document">
    <div class="mb-3 flex items-center justify-between gap-3">
      <div>
        <h3 id="help-title" class="text-sm font-semibold text-gray-900">Keyboard shortcuts</h3>
        <p class="mt-1 text-[11px] text-gray-500">Designed for fast keyboard navigation across CV, TUI, and slides modes.</p>
      </div>
      <button
        id="help-close"
        type="button"
        class="text-xs text-gray-500 hover:text-gray-800"
        aria-label="Close help"
      >
        ✕ esc
      </button>
    </div>
    <table class="w-full text-[12.5px] text-gray-700">
      <tbody>
        <tr class="border-b border-gray-100"><td class="py-1.5"><kbd class="help-kbd">?</kbd></td><td>Toggle help</td></tr>
        <tr class="border-b border-gray-100"><td class="py-1.5"><kbd class="help-kbd">1</kbd><kbd class="help-kbd">2</kbd><kbd class="help-kbd">3</kbd></td><td>Switch CV / TUI / slides modes</td></tr>
        <tr class="border-b border-gray-100"><td class="py-1.5"><kbd class="help-kbd">l</kbd></td><td>Toggle language EN ↔ ES</td></tr>
        <tr class="border-b border-gray-100"><td class="py-1.5"><kbd class="help-kbd">p</kbd></td><td>Export to PDF (system print)</td></tr>
        <tr class="border-b border-gray-100"><td class="py-1.5"><kbd class="help-kbd">j</kbd><kbd class="help-kbd">k</kbd></td><td>Scroll down / up</td></tr>
        <tr class="border-b border-gray-100"><td class="py-1.5"><kbd class="help-kbd">[</kbd><kbd class="help-kbd">]</kbd></td><td>Previous / next section</td></tr>
        <tr class="border-b border-gray-100"><td class="py-1.5"><kbd class="help-kbd">g</kbd><kbd class="help-kbd">G</kbd></td><td>Jump to top / bottom</td></tr>
        <tr class="border-b border-gray-100"><td class="py-1.5"><kbd class="help-kbd">H</kbd><kbd class="help-kbd">M</kbd><kbd class="help-kbd">L</kbd></td><td>Align current section top / middle / bottom</td></tr>
        <tr class="border-b border-gray-100"><td class="py-1.5"><kbd class="help-kbd">:</kbd></td><td>Open command prompt in TUI mode</td></tr>
        <tr class="border-b border-gray-100"><td class="py-1.5"><kbd class="help-kbd">↑</kbd><kbd class="help-kbd">↓</kbd><kbd class="help-kbd">Tab</kbd></td><td>Command history and completion</td></tr>
        <tr class="border-b border-gray-100"><td class="py-1.5"><kbd class="help-kbd">/</kbd></td><td>Search visible sections and jump to matches</td></tr>
        <tr class="border-b border-gray-100"><td class="py-1.5"><kbd class="help-kbd">←</kbd><kbd class="help-kbd">→</kbd><kbd class="help-kbd">space</kbd></td><td>Prev / Next slide (slides mode)</td></tr>
        <tr><td class="py-1.5"><kbd class="help-kbd">esc</kbd></td><td>Close help, search, or command prompt first</td></tr>
      </tbody>
    </table>
    <p class="mt-3 text-[11px] text-gray-500">
      Commands: <code>:help</code>
      <code>:mode cv|tui|slides</code>
      <code>:lang en|es</code>
      <code>:print</code>
      <code>:gh</code>
      <code>:li</code>
      <code>:web</code>
      <code>:mail</code>
      <code>:top</code>
      <code>:bottom</code>
      <code>:next</code>
      <code>:prev</code>
      <code>:about</code>
      <code>:skills</code>
    </p>
  </div>
</div>

<style>
  .help-kbd {
    display: inline-block;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    background: #f1f5f9;
    border: 1px solid #cbd5e1;
    border-radius: 4px;
    padding: 1px 6px;
    margin-right: 4px;
    font-size: 11px;
    color: #334155;
  }
</style>

<script>
  type Mode = "cv" | "tui" | "slides";
  type Lang = "en" | "es";

  const VALID_MODES: Mode[] = ["cv", "tui", "slides"];
  const VALID_LANGS: Lang[] = ["en", "es"];
  const COMMANDS = [
    "help",
    "quit",
    "mode cv",
    "mode tui",
    "mode slides",
    "lang en",
    "lang es",
    "print",
    "gh",
    "li",
    "web",
    "mail",
    "top",
    "bottom",
    "next",
    "prev",
    "intro",
    "about",
    "experience",
    "education",
    "skills",
    "languages",
    "section intro",
    "section about",
    "section experience",
    "section education",
    "section skills",
    "section languages",
  ];

  const root = document.documentElement;
  const KEY_MODE = "cv:mode";
  const KEY_LANG = "cv:lang";
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const modeEl = document.getElementById("sb-mode")!;
  const langEl = document.getElementById("sb-lang")!;
  const currentEl = document.getElementById("sb-current")!;
  const slideSeg = document.getElementById("sb-slide")!;
  const slideText = document.getElementById("sb-slide-text")!;
  const progressFill = document.getElementById("slide-progress-fill")! as HTMLElement;
  const helpModal = document.getElementById("help-modal")! as HTMLDivElement;
  const helpOpen = document.getElementById("help-open")! as HTMLButtonElement;
  const helpClose = document.getElementById("help-close")! as HTMLButtonElement;
  const commandOpen = document.getElementById("command-open")! as HTMLButtonElement;
  const searchOpen = document.getElementById("search-open")! as HTMLButtonElement;
  const cmdPrompt = document.getElementById("cmd-prompt")! as HTMLDivElement;
  const cmdInput = document.getElementById("cmd-input")! as HTMLInputElement;
  const searchPrompt = document.getElementById("search-prompt")! as HTMLDivElement;
  const searchInput = document.getElementById("search-input")! as HTMLInputElement;
  const searchMeta = document.getElementById("search-meta")!;
  const cmdEcho = document.getElementById("cmd-echo")!;
  const srUpdates = document.getElementById("sr-updates")!;
  const main = document.getElementById("main-content")! as HTMLElement;

  let currentSlide = 0;
  let slideSections: HTMLElement[] = [];
  let commandHistory: string[] = [];
  let historyIndex = -1;
  let searchMatches: HTMLElement[] = [];
  let searchIndex = 0;
  let currentSectionKey = "intro";
  let pendingG = false;
  let pendingGTimer: number | undefined;
  let lastFocused: HTMLElement | null = null;

  const labelForMode: Record<Mode, string> = {
    cv: "CV",
    tui: "TUI",
    slides: "SLIDES",
  };

  function safeScroll(top: number) {
    window.scrollTo({ top, behavior: prefersReducedMotion ? "auto" : "smooth" });
  }

  function safeScrollBy(top: number) {
    window.scrollBy({ top, behavior: prefersReducedMotion ? "auto" : "smooth" });
  }

  function getMode(): Mode {
    const stored = localStorage.getItem(KEY_MODE);
    return VALID_MODES.includes(stored as Mode) ? (stored as Mode) : "cv";
  }

  function getLang(): Lang {
    const stored = localStorage.getItem(KEY_LANG);
    return VALID_LANGS.includes(stored as Lang) ? (stored as Lang) : "en";
  }

  function setAnnouncement(message: string) {
    srUpdates.textContent = message;
  }

  function activeWrap(): HTMLElement | null {
    return document.querySelector(`[data-lang-wrap="${getLang()}"]`);
  }

  function sectionNodes(): HTMLElement[] {
    const wrap = activeWrap();
    if (!wrap) return [];
    return Array.from(wrap.querySelectorAll("[data-search-section]")) as HTMLElement[];
  }

  function updateCurrentSection(sectionName?: string, sectionKey?: string) {
    const fallback = sectionName || "Intro";
    currentSectionKey = sectionKey || currentSectionKey || "intro";
    currentEl.textContent = fallback;
    main.dataset.currentSection = fallback;
    main.dataset.currentSectionKey = currentSectionKey;
  }

  function updateSearchMeta() {
    searchMeta.textContent = `${searchMatches.length} match${searchMatches.length === 1 ? "" : "es"}`;
  }

  function collectSlides() {
    const wrap = activeWrap();
    if (!wrap) return;
    slideSections = Array.from(wrap.children).filter(
      (child): child is HTMLElement => child instanceof HTMLElement && !child.classList.contains("cv-only"),
    );
  }

  function goToSlide(idx: number) {
    if (!slideSections.length) return;
    currentSlide = Math.max(0, Math.min(idx, slideSections.length - 1));
    slideSections.forEach((el, index) => {
      el.classList.toggle("slide-active", index === currentSlide);
    });
    const total = slideSections.length;
    slideText.textContent = `[${currentSlide + 1}/${total}]`;
    progressFill.style.width = `${((currentSlide + 1) / total) * 100}%`;
    const currentLabel =
      slideSections[currentSlide]?.getAttribute("data-search-label") ||
      slideSections[currentSlide]?.querySelector("h1, h2")?.textContent?.trim() ||
      `Slide ${currentSlide + 1}`;
    const currentKey = slideSections[currentSlide]?.getAttribute("data-section-key") || undefined;
    updateCurrentSection(currentLabel, currentKey);
  }

  function nextSlide() {
    goToSlide(currentSlide + 1);
  }

  function prevSlide() {
    goToSlide(currentSlide - 1);
  }

  function applyMode(mode: Mode) {
    root.setAttribute("data-mode", mode);
    localStorage.setItem(KEY_MODE, mode);
    modeEl.textContent = labelForMode[mode];
    if (mode === "slides") {
      collectSlides();
      goToSlide(currentSlide);
      slideSeg.removeAttribute("hidden");
    } else {
      slideSeg.setAttribute("hidden", "");
      document.querySelectorAll(".slide-active").forEach((el) => el.classList.remove("slide-active"));
      updateCurrentSection("Intro", "intro");
    }
    if (mode !== "tui") {
      closeCmd();
      closeSearch();
    }
    setAnnouncement(`Mode set to ${labelForMode[mode]}`);
  }

  function applyLang(lang: Lang) {
    root.setAttribute("data-lang", lang);
    root.setAttribute("lang", lang);
    localStorage.setItem(KEY_LANG, lang);
    langEl.textContent = lang.toUpperCase();
    updateCurrentSection("Intro", "intro");
    if (getMode() === "slides") {
      collectSlides();
      goToSlide(0);
    }
    setAnnouncement(`Language set to ${lang.toUpperCase()}`);
  }

  function focusPrompt(input: HTMLInputElement) {
    window.setTimeout(() => input.focus(), 10);
  }

  function openHelp() {
    lastFocused = document.activeElement instanceof HTMLElement ? document.activeElement : null;
    helpModal.hidden = false;
    helpOpen.setAttribute("aria-expanded", "true");
    focusPrompt(helpClose as unknown as HTMLInputElement);
  }

  function closeHelp() {
    helpModal.hidden = true;
    helpOpen.setAttribute("aria-expanded", "false");
    lastFocused?.focus();
  }

  function openCmd() {
    if (getMode() !== "tui") {
      echo("Switch to TUI mode to use commands", true);
      return;
    }
    lastFocused = document.activeElement instanceof HTMLElement ? document.activeElement : null;
    cmdPrompt.hidden = false;
    cmdInput.value = "";
    historyIndex = commandHistory.length;
    focusPrompt(cmdInput);
  }

  function closeCmd() {
    cmdPrompt.hidden = true;
    cmdInput.blur();
  }

  function openSearch() {
    lastFocused = document.activeElement instanceof HTMLElement ? document.activeElement : null;
    searchPrompt.hidden = false;
    searchInput.value = "";
    searchMatches = [];
    searchIndex = 0;
    updateSearchMeta();
    focusPrompt(searchInput);
  }

  function closeSearch() {
    searchPrompt.hidden = true;
    searchInput.blur();
    lastFocused?.focus();
  }

  function echo(msg: string, err = false) {
    cmdEcho.textContent = msg;
    cmdEcho.classList.toggle("cmd-err", err);
    cmdEcho.setAttribute("data-visible", "true");
    setAnnouncement(msg);
    window.clearTimeout((echo as typeof echo & { _t?: number })._t);
    (echo as typeof echo & { _t?: number })._t = window.setTimeout(() => {
      cmdEcho.setAttribute("data-visible", "false");
    }, 4000);
  }

  function runCommand(raw: string) {
    const cmd = raw.trim();
    if (!cmd) return;
    if (commandHistory.at(-1) !== cmd) {
      commandHistory.push(cmd);
    }
    historyIndex = commandHistory.length;
    const [head, ...rest] = cmd.split(/\s+/);
    const arg = rest.join(" ");
    switch (head.toLowerCase()) {
      case "h":
      case "help":
        openHelp();
        echo("Help opened");
        break;
      case "q":
      case "quit":
        applyMode("cv");
        echo("Back to CV mode");
        break;
      case "mode":
        if (VALID_MODES.includes(arg as Mode)) {
          applyMode(arg as Mode);
          echo(`Mode → ${arg}`);
        } else {
          echo("Usage: :mode cv|tui|slides", true);
        }
        break;
      case "lang":
        if (VALID_LANGS.includes(arg as Lang)) {
          applyLang(arg as Lang);
          echo(`Language → ${arg}`);
        } else {
          echo("Usage: :lang en|es", true);
        }
        break;
      case "p":
      case "print":
      case "pdf":
        window.print();
        break;
      case "gh":
      case "github":
        window.open("https://github.com/FullFran", "_blank", "noopener,noreferrer");
        echo("Opened GitHub");
        break;
      case "li":
      case "linkedin":
        window.open("https://www.linkedin.com/in/franciscoolmedo-cortes/", "_blank", "noopener,noreferrer");
        echo("Opened LinkedIn");
        break;
      case "web":
        window.open("https://www.fullfran.com", "_blank", "noopener,noreferrer");
        echo("Opened website");
        break;
      case "mail":
      case "email":
        window.location.href = "mailto:franciscomanuelolmedocortes@gmail.com";
        break;
      case "top":
        safeScroll(0);
        break;
      case "bottom":
        safeScroll(document.body.scrollHeight);
        break;
      case "next":
        jumpSection(1);
        break;
      case "prev":
      case "previous":
        jumpSection(-1);
        break;
      case "section":
        if (goToSection(arg)) {
          echo(`Section → ${arg}`);
        } else {
          echo("Usage: :section intro|about|experience|education|skills|languages", true);
        }
        break;
      case "intro":
      case "about":
      case "experience":
      case "education":
      case "skills":
      case "languages":
        goToSection(head.toLowerCase());
        break;
      default:
        echo(`Unknown command: ${head}`, true);
    }
  }

  function sectionIndex() {
    const sections = sectionNodes();
    const directIndex = sections.findIndex((section) => section.getAttribute("data-section-key") === currentSectionKey);
    if (directIndex >= 0) return directIndex;
    const viewportMiddle = window.scrollY + window.innerHeight / 2;
    return sections.reduce((closestIndex, section, index) => {
      const currentDistance = Math.abs(section.offsetTop - viewportMiddle);
      const closestDistance = Math.abs(sections[closestIndex]?.offsetTop - viewportMiddle);
      return currentDistance < closestDistance ? index : closestIndex;
    }, 0);
  }

  function goToSection(key: string) {
    const normalized = key.trim().toLowerCase();
    const target = sectionNodes().find((section) => section.getAttribute("data-section-key") === normalized);
    if (!target) return false;
    const label = target.getAttribute("data-search-label") || target.querySelector("h1, h2")?.textContent?.trim() || normalized;
    target.scrollIntoView({ block: "start", behavior: prefersReducedMotion ? "auto" : "smooth" });
    updateCurrentSection(label, normalized);
    return true;
  }

  function jumpSection(direction: 1 | -1) {
    const sections = sectionNodes();
    if (!sections.length) return;
    const nextIndex = Math.max(0, Math.min(sectionIndex() + direction, sections.length - 1));
    const target = sections[nextIndex];
    const key = target.getAttribute("data-section-key") || "intro";
    const label = target.getAttribute("data-search-label") || target.querySelector("h1, h2")?.textContent?.trim() || "Section";
    target.scrollIntoView({ block: "start", behavior: prefersReducedMotion ? "auto" : "smooth" });
    updateCurrentSection(label, key);
    echo(`${direction > 0 ? "Next" : "Previous"} section → ${label}`);
  }

  function completeCommand(value: string) {
    const query = value.trim().toLowerCase();
    if (!query) return ":help";
    const cleanQuery = query.startsWith(":") ? query.slice(1) : query;
    const match = COMMANDS.find((command) => command.startsWith(cleanQuery));
    return match ? `:${match}` : value;
  }

  function updateSearchMatches(query: string) {
    const normalized = query.trim().toLowerCase();
    if (!normalized) {
      searchMatches = [];
      searchIndex = 0;
      updateSearchMeta();
      return;
    }
    searchMatches = sectionNodes().filter((section) => {
      const haystack = `${section.getAttribute("data-search-label") || ""} ${section.textContent || ""}`.toLowerCase();
      return haystack.includes(normalized);
    });
    searchIndex = 0;
    updateSearchMeta();
  }

  function jumpToMatch(index = 0) {
    if (!searchMatches.length) {
      echo("No matches found", true);
      return;
    }
    const target = searchMatches[((index % searchMatches.length) + searchMatches.length) % searchMatches.length];
    const label = target.getAttribute("data-search-label") || target.querySelector("h1, h2")?.textContent?.trim() || "Section";
    target.scrollIntoView({ block: "start", behavior: prefersReducedMotion ? "auto" : "smooth" });
    const key = target.getAttribute("data-section-key") || undefined;
    updateCurrentSection(label, key);
    echo(`Jumped to ${label}`);
  }

  function armG() {
    pendingG = true;
    window.clearTimeout(pendingGTimer);
    pendingGTimer = window.setTimeout(() => (pendingG = false), 600);
  }

  function trapFocus(event: KeyboardEvent) {
    if (event.key !== "Tab" || helpModal.hidden) return;
    const focusable = helpModal.querySelectorAll<HTMLElement>('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])');
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (!first || !last) return;
    if (event.shiftKey && document.activeElement === first) {
      event.preventDefault();
      last.focus();
    } else if (!event.shiftKey && document.activeElement === last) {
      event.preventDefault();
      first.focus();
    }
  }

  function alignCurrentSection(position: "start" | "center" | "end") {
    const current = sectionNodes().find((section) => section.getAttribute("data-section-key") === currentSectionKey);
    current?.scrollIntoView({ block: position, behavior: prefersReducedMotion ? "auto" : "smooth" });
  }

  function observeSections() {
    const sections = sectionNodes();
    if (!sections.length) return;
    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        if (!visible) return;
        const label =
          visible.target.getAttribute("data-search-label") ||
          visible.target.querySelector("h1, h2")?.textContent?.trim() ||
          "Intro";
        const key = visible.target.getAttribute("data-section-key") || undefined;
        updateCurrentSection(label, key);
      },
      { rootMargin: "-20% 0px -55% 0px", threshold: [0.2, 0.45, 0.7] },
    );
    sections.forEach((section) => observer.observe(section));
  }

  cmdInput.addEventListener("keydown", (event) => {
    if (event.key === "Enter") {
      event.preventDefault();
      const value = cmdInput.value.replace(/^:/, "");
      closeCmd();
      runCommand(value);
      return;
    }
    if (event.key === "Escape") {
      event.preventDefault();
      closeCmd();
      lastFocused?.focus();
      return;
    }
    if (event.key === "ArrowUp") {
      event.preventDefault();
      if (!commandHistory.length) return;
      historyIndex = Math.max(0, historyIndex - 1);
      cmdInput.value = `:${commandHistory[historyIndex]}`;
      cmdInput.setSelectionRange(cmdInput.value.length, cmdInput.value.length);
      return;
    }
    if (event.key === "ArrowDown") {
      event.preventDefault();
      if (!commandHistory.length) return;
      historyIndex = Math.min(commandHistory.length, historyIndex + 1);
      cmdInput.value = historyIndex >= commandHistory.length ? "" : `:${commandHistory[historyIndex]}`;
      cmdInput.setSelectionRange(cmdInput.value.length, cmdInput.value.length);
      return;
    }
    if (event.key === "Tab") {
      event.preventDefault();
      cmdInput.value = completeCommand(cmdInput.value);
      cmdInput.setSelectionRange(cmdInput.value.length, cmdInput.value.length);
    }
  });

  searchInput.addEventListener("input", () => updateSearchMatches(searchInput.value));
  searchInput.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      event.preventDefault();
      closeSearch();
      return;
    }
    if (event.key === "Enter") {
      event.preventDefault();
      jumpToMatch(searchIndex);
      return;
    }
    if (event.key === "ArrowDown") {
      event.preventDefault();
      if (!searchMatches.length) return;
      searchIndex = (searchIndex + 1) % searchMatches.length;
      jumpToMatch(searchIndex);
      return;
    }
    if (event.key === "ArrowUp") {
      event.preventDefault();
      if (!searchMatches.length) return;
      searchIndex = (searchIndex - 1 + searchMatches.length) % searchMatches.length;
      jumpToMatch(searchIndex);
    }
  });

  document.addEventListener("keydown", (event) => {
    const target = event.target as HTMLElement;
    const typing =
      target &&
      (target.tagName === "INPUT" || target.tagName === "TEXTAREA" || target.isContentEditable);

    trapFocus(event);

    if (typing && target !== cmdInput && target !== searchInput) return;

    if (!helpModal.hidden) {
      if (event.key === "Escape" || event.key === "?") {
        event.preventDefault();
        closeHelp();
      }
      return;
    }

    if (target === searchInput || target === cmdInput) return;

    switch (event.key) {
      case "?":
        event.preventDefault();
        openHelp();
        return;
      case "Escape":
        if (!searchPrompt.hidden) {
          event.preventDefault();
          closeSearch();
          return;
        }
        if (!cmdPrompt.hidden) {
          event.preventDefault();
          closeCmd();
          return;
        }
        if (getMode() !== "cv") {
          applyMode("cv");
        }
        return;
      case "1":
        applyMode("cv");
        return;
      case "2":
        applyMode("tui");
        return;
      case "3":
        applyMode("slides");
        return;
      case "l":
        applyLang(getLang() === "en" ? "es" : "en");
        return;
      case "p":
      case "P":
        event.preventDefault();
        window.print();
        return;
      case "/":
        event.preventDefault();
        openSearch();
        return;
      case ":":
        event.preventDefault();
        openCmd();
        return;
      case "j":
        if (getMode() !== "slides") safeScrollBy(80);
        return;
      case "k":
        if (getMode() !== "slides") safeScrollBy(-80);
        return;
      case "]":
        if (getMode() !== "slides") jumpSection(1);
        return;
      case "[":
        if (getMode() !== "slides") jumpSection(-1);
        return;
      case "g":
        if (getMode() === "slides") {
          goToSlide(0);
        } else if (pendingG) {
          safeScroll(0);
          pendingG = false;
        } else {
          armG();
        }
        return;
      case "G":
        if (getMode() === "slides") {
          goToSlide(slideSections.length - 1);
        } else {
          safeScroll(document.body.scrollHeight);
        }
        return;
      case "H":
        alignCurrentSection("start");
        return;
      case "M":
        alignCurrentSection("center");
        return;
      case "L":
        alignCurrentSection("end");
        return;
      case "ArrowRight":
      case " ":
        if (getMode() === "slides") {
          event.preventDefault();
          nextSlide();
        }
        return;
      case "ArrowLeft":
      case "b":
        if (getMode() === "slides") {
          event.preventDefault();
          prevSlide();
        }
        return;
    }
  });

  helpOpen.addEventListener("click", openHelp);
  helpClose.addEventListener("click", closeHelp);
  helpModal.addEventListener("click", (event) => {
    if (event.target === helpModal) closeHelp();
  });
  commandOpen.addEventListener("click", openCmd);
  searchOpen.addEventListener("click", openSearch);

  applyLang(getLang());
  applyMode(getMode());
  observeSections();
</script>
